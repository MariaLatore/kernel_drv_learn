0.Driver build, please refer to the mysecure&myproject of this repo

1.Add device to qemu src
zxy@debian:~/workspace/30Gsda5/Miscellaneous/qemu-10.0.8$ cat hw/misc/fakebell.c 
/*
 * Fake Bell device: minimal MMIO + IRQ demo device
 */

#include "qemu/osdep.h"
#include "hw/sysbus.h"
#include "qapi/error.h"
#include "qemu/module.h"
#include "qemu/timer.h"
#include "hw/irq.h"
#include "migration/vmstate.h"

#define TYPE_FAKEBELL "fakebell"
OBJECT_DECLARE_SIMPLE_TYPE(FakeBellState, FAKEBELL)

#define FB_REG_STATUS        0x00
#define FB_REG_IRQ_ENABLE    0x04
#define FB_REG_IRQ_STATUS    0x08
#define FB_REG_IRQ_ACK       0x0c
#define FB_REG_EVENT_COUNT   0x10

#define FB_STATUS_EVENT_ACTIVE   (1u << 0)
#define FB_IRQ_ENABLE_EN         (1u << 0)
#define FB_IRQ_STATUS_PENDING    (1u << 0)

typedef struct FakeBellState {
    SysBusDevice parent_obj;

    MemoryRegion mmio;
    qemu_irq irq;
    QEMUTimer *timer;

    uint32_t status;
    uint32_t irq_enable;
    uint32_t irq_status;
    uint32_t event_count;
} FakeBellState;

static void fakebell_update_irq(FakeBellState *s)
{
    if ((s->irq_enable & FB_IRQ_ENABLE_EN) &&
        (s->irq_status & FB_IRQ_STATUS_PENDING)) {
        fprintf(stderr,
                "fakebell: IRQ assert irq_enable=0x%x irq_status=0x%x event_count=%u\n",
                s->irq_enable, s->irq_status, s->event_count);
        qemu_set_irq(s->irq, 1);
    } else {
        fprintf(stderr,
                "fakebell: IRQ deassert irq_enable=0x%x irq_status=0x%x event_count=%u\n",
                s->irq_enable, s->irq_status, s->event_count);
        qemu_set_irq(s->irq, 0);
    }
	fprintf(stderr, "ZZZ_UPDATE_IRQ enable=0x%x pending=0x%x event_count=%u\n",
        s->irq_enable, s->irq_status, s->event_count);
}

static uint64_t fakebell_read(void *opaque, hwaddr offset, unsigned size)
{
    FakeBellState *s = opaque;
    uint64_t val = 0;

    if (size != 4) {
        fprintf(stderr,
                "fakebell: invalid read size=%u offset=0x%lx\n",
                size, (unsigned long)offset);
        return 0;
    }

    switch (offset) {
    case FB_REG_STATUS:
        val = s->status;
        break;
    case FB_REG_IRQ_ENABLE:
        val = s->irq_enable;
        break;
    case FB_REG_IRQ_STATUS:
        val = s->irq_status;
        break;
    case FB_REG_EVENT_COUNT:
        val = s->event_count;
        break;
    case FB_REG_IRQ_ACK:
    default:
        val = 0;
        break;
    }

    fprintf(stderr,
            "fakebell: read offset=0x%lx size=%u -> 0x%lx\n",
            (unsigned long)offset, size, (unsigned long)val);

    return val;
}

static void fakebell_write(void *opaque, hwaddr offset, uint64_t value,
                           unsigned size)
{
    FakeBellState *s = opaque;

    fprintf(stderr,
            "ZZZ_WRITE enter offset=0x%lx size=%u value=0x%lx status=0x%x irq_status=0x%x irq_enable=0x%x event_count=%u\n",
            (unsigned long)offset, size, (unsigned long)value,
            s->status, s->irq_status, s->irq_enable, s->event_count);

    if (size != 4) {
        fprintf(stderr,
                "ZZZ_WRITE invalid size=%u offset=0x%lx value=0x%lx\n",
                size, (unsigned long)offset, (unsigned long)value);
        return;
    }

    switch (offset) {
    case FB_REG_IRQ_ENABLE:
        fprintf(stderr, "ZZZ_WRITE IRQ_ENABLE before=0x%x\n", s->irq_enable);
        s->irq_enable = value & FB_IRQ_ENABLE_EN;
        fprintf(stderr, "ZZZ_WRITE IRQ_ENABLE after=0x%x\n", s->irq_enable);
        fakebell_update_irq(s);
        break;

    case FB_REG_IRQ_ACK:
        fprintf(stderr,
                "ZZZ_WRITE IRQ_ACK before clear status=0x%x irq_status=0x%x\n",
                s->status, s->irq_status);
        if (value & 0x1) {
            s->status = 0;
            s->irq_status = 0;
            fprintf(stderr,
                    "ZZZ_WRITE IRQ_ACK after clear status=0x%x irq_status=0x%x\n",
                    s->status, s->irq_status);
            fakebell_update_irq(s);
        }
        break;

    default:
        fprintf(stderr, "ZZZ_WRITE unknown offset=0x%lx ignored\n",
                (unsigned long)offset);
        break;
    }
}

static const MemoryRegionOps fakebell_ops = {
    .read = fakebell_read,
    .write = fakebell_write,
    .endianness = DEVICE_LITTLE_ENDIAN,
    .valid.min_access_size = 4,
    .valid.max_access_size = 4,
};

static void fakebell_timer_cb(void *opaque)
{
    FakeBellState *s = opaque;
    int64_t now;

    fprintf(stderr,
            "fakebell: timer enter: status=0x%x irq_enable=0x%x irq_status=0x%x event_count=%u\n",
            s->status, s->irq_enable, s->irq_status, s->event_count);

    if (!(s->irq_status & FB_IRQ_STATUS_PENDING)) {
        s->event_count++;
        s->status = FB_STATUS_EVENT_ACTIVE;
        s->irq_status = FB_IRQ_STATUS_PENDING;

        fprintf(stderr,
                "fakebell: timer fired new event: event_count=%u status=0x%x irq_status=0x%x\n",
                s->event_count, s->status, s->irq_status);

        fakebell_update_irq(s);
    } else {
        fprintf(stderr,
                "fakebell: timer skip, pending still set: status=0x%x irq_enable=0x%x irq_status=0x%x event_count=%u\n",
                s->status, s->irq_enable, s->irq_status, s->event_count);
    }

    now = qemu_clock_get_ms(QEMU_CLOCK_VIRTUAL);
    timer_mod(s->timer, now + 2000);
}

static void fakebell_realize(DeviceState *dev, Error **errp)
{
    FakeBellState *s = FAKEBELL(dev);
    int64_t now;

    s->status = 0;
    s->irq_enable = 0;
    s->irq_status = 0;
    s->event_count = 0;
    qemu_set_irq(s->irq, 0);

    fprintf(stderr, "fakebell: realize done, timer start\n");

    s->timer = timer_new_ms(QEMU_CLOCK_VIRTUAL, fakebell_timer_cb, s);
    now = qemu_clock_get_ms(QEMU_CLOCK_VIRTUAL);
    timer_mod(s->timer, now + 2000);
}

static void fakebell_unrealize(DeviceState *dev)
{
    FakeBellState *s = FAKEBELL(dev);

    fprintf(stderr, "fakebell: unrealize\n");

    if (s->timer) {
        timer_del(s->timer);
        timer_free(s->timer);
        s->timer = NULL;
    }
}

static void fakebell_init(Object *obj)
{
    FakeBellState *s = FAKEBELL(obj);

    fprintf(stderr, "fakebell: init object\n");

    memory_region_init_io(&s->mmio, obj, &fakebell_ops, s,
                          "fakebell-mmio", 0x1000);
    sysbus_init_mmio(SYS_BUS_DEVICE(obj), &s->mmio);
    sysbus_init_irq(SYS_BUS_DEVICE(obj), &s->irq);
}

static const VMStateDescription vmstate_fakebell = {
    .name = TYPE_FAKEBELL,
    .version_id = 1,
    .minimum_version_id = 1,
    .fields = (VMStateField[]) {
        VMSTATE_UINT32(status, FakeBellState),
        VMSTATE_UINT32(irq_enable, FakeBellState),
        VMSTATE_UINT32(irq_status, FakeBellState),
        VMSTATE_UINT32(event_count, FakeBellState),
        VMSTATE_END_OF_LIST()
    }
};

static void fakebell_class_init(ObjectClass *klass, void *data)
{
    DeviceClass *dc = DEVICE_CLASS(klass);

    fprintf(stderr, "fakebell: class init\n");

    dc->realize = fakebell_realize;
    dc->unrealize = fakebell_unrealize;
    dc->vmsd = &vmstate_fakebell;
    dc->desc = "Minimal fake bell MMIO/IRQ device";
}

static const TypeInfo fakebell_info = {
    .name          = TYPE_FAKEBELL,
    .parent        = TYPE_SYS_BUS_DEVICE,
    .instance_size = sizeof(FakeBellState),
    .instance_init = fakebell_init,
    .class_init    = fakebell_class_init,
};

static void fakebell_register_types(void)
{
    fprintf(stderr, "fakebell: register type\n");
    type_register_static(&fakebell_info);
}

type_init(fakebell_register_types)
