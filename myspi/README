│       ├── bind
│       ├── module -> ../../../../module/myspidrv
│       ├── spi0.0 -> ../../../../devices/platform/fake-spi-parent/spi_master/spi0/spi0.0
│       ├── uevent
│       └── unbind
├── drivers_autoprobe
├── drivers_probe
└── uevent

8 directories, 9 files
zxy@debian:/sys/bus/spi$ 

