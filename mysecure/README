1. To make this work, do the following:
	a) copy the dir mysecure under <kernel src>/driver/ 
	b) add Kconfig:
		zxy@debian:~/workspace/30Gsda5/linux-6.12.75$ tail drivers/Kconfig 
		source "drivers/hte/Kconfig"

		source "drivers/cdx/Kconfig"

		source "drivers/dpll/Kconfig"

		source "drivers/helloworld/Kconfig"

		source "drivers/mysecure/Kconfig"
		endmenu
		zxy@debian:~/workspace/30Gsda5/linux-6.12.75$ 
	c) add Makefile
		zxy@debian:~/workspace/30Gsda5/linux-6.12.75$ tail drivers/Makefile 
		obj-$(CONFIG_MOST)		+= most/
		obj-$(CONFIG_PECI)		+= peci/
		obj-$(CONFIG_HTE)		+= hte/
		obj-$(CONFIG_DRM_ACCEL)		+= accel/
		obj-$(CONFIG_CDX_BUS)		+= cdx/
		obj-$(CONFIG_DPLL)		+= dpll/

		obj-$(CONFIG_S390)		+= s390/
		obj-$(CONFIG_HELLOWORLD)        += helloworld/
		obj-$(CONFIG_MYSECURE)          += mysecure/
		zxy@debian:~/workspace/30Gsda5/linux-6.12.75$ 
	d) change the .config file
		zxy@debian:~/workspace/30Gsda5/linux-6.12.75$ grep -ri 'mysecure' .config
		# MYSECURE support
		CONFIG_MYSECURE=y
		# end of MYSECURE support
		CONFIG_LSM="landlock,lockdown,yama,loadpin,safesetid,selinux,smack,tomoyo,apparmor,ipe,bpf,mysecure"
		zxy@debian:~/workspace/30Gsda5/linux-6.12.75$ 
	e) build the kernel and boot with below command
		qemu-system-x86_64 \
		  -kernel ~/workspace/30Gsda5/linux-6.12.75/arch/x86/boot/bzImage \
		  -hda ~/workspace/30Gsda5/buildroot/output/images/rootfs.ext2 \
		  -append "root=/dev/sda rootfstype=ext2 console=ttyS0,115200 noapic rootwait lsm=capability,zxylsm"\
		  -nographic -m 1024
	  if not use this command, will enounter fail:
		# dmesg | grep -Ei 'zxylsm|mysecure|LSM'
		[ 0.000000] Command line: root=/dev/sda rootfstype=ext2 console=ttyS0,115200 noapic rootwait lsm=capability,selinux,zxylsm
		[ 0.060965] Kernel command line: root=/dev/sda rootfstype=ext2 console=ttyS0,115200 noapic rootwait lsm=capability,selinux,zxylsm
             ***[ 0.189588] cmdline: out of LSM static calls!?
		[ 0.189588] WARNING: CPU: 0 PID: 0 at security/security.c:221 append_ordered_lsm+0x54/0xb0
		[ 0.189588] RIP: 0010:append_ordered_lsm+0x54/0xb0
		[ 0.190588] ordered_lsm_parse+0x129/0x260
		[ 0.191588] LSM: initializing lsm=capability,selinux
		#

2. To simply build/clean this module:
zxy@debian:~/workspace/30Gsda5/linux-6.12.75$ make M=drivers/mysecure clean
zxy@debian:~/workspace/30Gsda5/linux-6.12.75$ make M=drivers/mysecure V=1
make --no-print-directory -C /home/zxy/workspace/30Gsda5/linux-6.12.75 \
-f /home/zxy/workspace/30Gsda5/linux-6.12.75/Makefile 
make -f ./scripts/Makefile.build obj=drivers/mysecure need-builtin=1 need-modorder=1 
# cmd_gen_order drivers/mysecure/modules.order
  {  :; } > drivers/mysecure/modules.order
sh ./scripts/modules-check.sh drivers/mysecure/modules.order
make -f ./scripts/Makefile.modpost
# MODPOST drivers/mysecure/Module.symvers
   scripts/mod/modpost -M        -o drivers/mysecure/Module.symvers -n -T drivers/mysecure/modules.order -i Module.symvers -e 
make -f ./scripts/Makefile.modfinal
zxy@debian:~/workspace/30Gsda5/linux-6.12.75$ 

