3. make
host_diag$ cat Makefile
SRCS-y :=  mydpdk.c
APP := mydpdk
export PKG_CONFIG_PATH=/usr/local/lib64/pkgconfig:$PKG_CONFIG_PATH
PKGCONF := pkg-config
CFLAGS += -O3 $(shell $(PKGCONF) --cflags libdpdk)
LDFLAGS += $(shell $(PKGCONF) --libs libdpdk)

$(APP): $(SRCS-y) Makefile
        $(CC) -L/usr/local/lib64 $(CFLAGS) $(SRCS-y) -o $@ $(LDFLAGS)
host_diag$
host_diag$
